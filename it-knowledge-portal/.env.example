# API 配置
VITE_API_BASE_URL=/api
VITE_API_TIMEOUT=15000

# 公司信息（部署时替换）
VITE_COMPANY_NAME=企业IT
VITE_IT_EMAIL=it@example.com
VITE_HOTLINE=8000

# 系统地址
VITE_ERP_URL=https://erp.example.com
VITE_OA_URL=https://oa.example.com

# 上传配置
VITE_UPLOAD_MAX_SIZE=10485760
VITE_UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet

# 分页配置
VITE_DEFAULT_PAGE_SIZE=10
VITE_MAX_PAGE_SIZE=100
