# 数据库
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/it_services?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# 服务端口
PORT=3000

# 日志配置
LOG_LEVEL="info"
LOG_DIR="./logs"

# CORS (生产环境设置为前端域名)
CORS_ORIGIN="*"

# 文件上传
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760

# OSS/MinIO (可选，不配置则使用本地存储)
# OSS_ACCESS_KEY_ID=""
# OSS_ACCESS_KEY_SECRET=""
# OSS_BUCKET=""
# OSS_REGION=""
# OSS_ENDPOINT=""

# Redis (可选，用于缓存)
# REDIS_URL="redis://localhost:6379"

# Elasticsearch (可选，用于全文搜索)
# ELASTICSEARCH_URL="http://localhost:9200"

# 生产环境安全建议
# 1. 设置强 JWT_SECRET (至少32位随机字符串)
# 2. 设置 CORS_ORIGIN 为前端域名
# 3. 启用 HTTPS
# 4. 配置防火墙规则
# 5. 定期备份数据库
